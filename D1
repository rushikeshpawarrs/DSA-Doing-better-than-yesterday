#include<iostream>
using namespace std;
int fib(int num){
    if( num == 0)   return 0;
    if( num == 1)   return 1;
    
    int ans = fib(num - 1) + fib(num - 2);
    return ans;
}
int main(){
    int length;
    cout << "Enter the length of the fibonacci series" << endl;
    cin >> length;
    for(int i = 0; i < length; i++){
        int ans = fib(i);
        cout << ans << " " ;
    }
    return 0;
}
